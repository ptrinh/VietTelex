<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Developer ID / local build: NOT sandboxed (sandbox without a
         provisioning profile prevents input-method registration).
         Still zero network: no network entitlements declared. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
