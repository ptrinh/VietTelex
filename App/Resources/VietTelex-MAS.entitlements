<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Mac App Store build: sandbox required. Signed with Apple
         Distribution + a provisioning profile at submission time.
         No network entitlements (zero network). -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
</dict>
</plist>
