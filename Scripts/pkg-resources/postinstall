#!/bin/bash
# pkg postinstall — runs after VietTelex.app is written to
# ~/Library/Input Methods. Registers the input source and opens Keyboard
# settings, both in the CONSOLE USER's GUI session (the installer runs scripts
# as root; Text Input Source state and `open` must target the logged-in user).
set +e

DIR="$(cd "$(dirname "$0")" && pwd)"
consoleUser="$(stat -f%Su /dev/console)"
[ -z "$consoleUser" ] && consoleUser="$USER"
uid="$(id -u "$consoleUser")"
APP="/Users/$consoleUser/Library/Input Methods/VietTelex.app"

# Upgrade path: kill any RUNNING old instance so the next keystroke relaunches
# the freshly installed binary. Without this the old version keeps serving until
# logout — field report: pkg upgraded the bundle on disk but the app still ran
# (and reported) the previous version.
launchctl asuser "$uid" sudo -u "$consoleUser" pkill -x VietTelex 2>/dev/null

# Make LaunchServices aware of the freshly installed bundle.
LSREGISTER="/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister"
"$LSREGISTER" -f "$APP" 2>/dev/null

# Register + best-effort enable, inside the user's GUI session.
launchctl asuser "$uid" sudo -u "$consoleUser" "$DIR/register-source" "$APP" 2>/dev/null

# Drop the user straight into System Settings → Keyboard for the final "＋" step,
# and open the illustrated install guide (screenshots were removed from the
# conclusion screen — the guide IS the visual walkthrough now). Settings first so
# the browser ends up frontmost with the instructions.
launchctl asuser "$uid" sudo -u "$consoleUser" \
    open "x-apple.systempreferences:com.apple.Keyboard-Settings.extension" 2>/dev/null
launchctl asuser "$uid" sudo -u "$consoleUser" \
    open "https://ptrinh.github.io/viettelex/#install" 2>/dev/null

exit 0
